{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Antigravity": {
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta/"
  },
  "GeminiAgents": {
    "ApiKey": "${GEMINI_API_KEY}",
    "AgentsDefinitionFile": "Agents",
    "WorkflowsDefinitionFolder": "Agents/Gemini/agents/workflows",
    "SkillsDefinitionFolder": "Agents/Gemini/agents/skills",
    "CreateAgentEndpoint": "interactions"
  },
  "StreamingErrorPolicy": {
    "MaxRetries": 3,
    "InitialRetryDelay": "00:00:01",
    "RetryBackoffMultiplier": 2.0,
    "FunctionExecutionTimeout": "00:00:30",
    "StreamTimeout": "00:05:00"
  },
  "AzureTableStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "UsersTableName": "users",
    "VerificationTableName": "emailverifications",
    "LoginAttemptsTableName": "loginattempts"
  },
  "LoginAttempts": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 30
  },
  "Authentication": {
    "Jwt": {
      "SecretKey": "${JWT_SECRET_KEY}",
      "Issuer": "https://insightforge.local",
      "Audience": "insight-forge-api",
      "AccessTokenExpiryMinutes": 15,
      "RefreshTokenExpiryDays": 9
    },
    "Registration": {
      "EmailVerificationExpiryHours": "24",
      "MinPasswordLength": "8"
    },
    "Email": {
      "Provider": "mock",
      "FromAddress": "noreply@insightforge.com",
      "SenderName": "Insight Forge"
    }
  }
}
