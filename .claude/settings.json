{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(dotnet restore *)",
      "Bash(dotnet build *)",
      "Bash(dotnet test *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(gh *)"
    ]
  },
  "deny": [
    "Bash(curl *)",
    "Read(./.env)",
    "Read(./.env.*)",
    "Read(./secrets/**)"
  ]
}
